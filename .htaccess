# ---------------------------------------------------------------------------
# Top-level .htaccess.
#
# The document root for olympics.sportsbya.com is the public/ sub-folder, so
# routing is handled entirely by public/.htaccess. This file therefore does
# NOT forward requests into public/ — doing so caused rewrite loops.
#
# It only hardens the parent directory (deny listing, block dotfiles). If you
# are on a host where the document root CANNOT be set to public/, see
# DEPLOY-fallback note in README and restore the forwarding rule.
# ---------------------------------------------------------------------------

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct web access to application source if this folder is ever
    # served directly.
    RewriteRule ^(config|includes|controllers|models|views|database|logs|bin)(/|$) - [F,L]
    RewriteRule (^|/)\.(?!well-known) - [F,L]
</IfModule>
