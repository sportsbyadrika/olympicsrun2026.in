# ---------------------------------------------------------------------------
# Top-level .htaccess  (docroot-agnostic safety net)
#
# The Document Root for olympics.sportsbya.com is normally the public/
# sub-folder, in which case Apache never reads THIS file at all and
# public/.htaccess does all the routing.
#
# But if the Document Root ever drifts to this parent folder (a fresh
# subdomain, a cPanel reset, a mistaken setting), this file forwards every
# request into public/ so the site still serves instead of 404-ing. It is
# loop-safe: once a request is already inside public/, the first rule stops
# rewriting.
# ---------------------------------------------------------------------------

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Already inside public/ — hand off to public/.htaccess, do not rewrite
    # again (this short-circuit is what prevents the rewrite loop the old
    # forwarding rule suffered from).
    RewriteRule ^public/ - [L]

    # Forward everything else into the public/ front controller. Because all
    # requests are funnelled through public/, the sibling source folders
    # (config/, includes/, models/, ...) are never served directly from here.
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
