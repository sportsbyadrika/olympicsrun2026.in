# Front-controller routing for the Olympics Run app.
# Goal: work identically on Apache and LiteSpeed/cPanel shared hosting,
# without depending on the host's DirectoryIndex configuration.

DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Block direct web access to dotfiles (.git, .env, .htaccess, ...).
    RewriteRule "(^|/)\.(?!well-known)" - [F]

    # Site root -> front controller, stated explicitly so "/" works even when
    # the host does not apply a useful DirectoryIndex to this docroot. (This
    # was the cause of the homepage-only 404.)
    RewriteRule ^$ index.php [L]

    # Let real files and directories (css/js/img/vendor) be served as-is.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Everything else -> front controller.
    RewriteRule ^ index.php [L]
</IfModule>

# Never expose a directory listing.
Options -Indexes
