# Local config (real credentials live outside the repo)
config/config.local.php
config/database.local.php
.env
.env.local

# Runtime artefacts
/uploads/*
!/uploads/.gitkeep
!/uploads/participants/
/uploads/participants/*
!/uploads/participants/.gitkeep
/logs/*
!/logs/.gitkeep

# Session files (app-local session store) — keep the dir, ignore its contents
/storage/sessions/*
!/storage/sessions/.gitignore

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Composer (if added later)
/vendor/
composer.lock

# Build output
/public/css/dist/
/public/js/dist/
